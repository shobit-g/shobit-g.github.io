    <!-- Project Content -->
    <section class="project-content">
        <div class="container">
            <div class="content-grid">
                <div class="main-content">
                    <!-- Overview -->
                    <div class="content-section">
                        <h2>Project Overview</h2>
                        <p>
                            Designed and implemented a comprehensive multi-cluster Kubernetes automation solution 
                            for a large enterprise with 20+ development teams. The project aimed to streamline 
                            deployment processes, ensure consistency across environments, and reduce deployment 
                            time from hours to minutes using GitOps principles.
                        </p>
                        <p>
                            The solution manages 15 Kubernetes clusters across different regions and environments 
                            (dev, staging, production), serving over 200 microservices with zero-downtime deployments 
                            and automated rollbacks.
                        </p>
                    </div>

                    <!-- Challenge -->
                    <div class="content-section">
                        <h2>The Challenge</h2>
                        <div class="challenge-list">
                            <div class="challenge-item">
                                <i class="fas fa-exclamation-triangle"></i>
                                <div>
                                    <h4>Manual Deployment Process</h4>
                                    <p>Teams were manually deploying to multiple clusters, leading to inconsistencies and errors</p>
                                </div>
                            </div>
                            <div class="challenge-item">
                                <i class="fas fa-exclamation-triangle"></i>
                                <div>
                                    <h4>Configuration Drift</h4>
                                    <p>Clusters had different configurations, making troubleshooting and maintenance difficult</p>
                                </div>
                            </div>
                            <div class="challenge-item">
                                <i class="fas fa-exclamation-triangle"></i>
                                <div>
                                    <h4>Slow Rollbacks</h4>
                                    <p>Rolling back failed deployments took significant time and manual intervention</p>
                                </div>
                            </div>
                            <div class="challenge-item">
                                <i class="fas fa-exclamation-triangle"></i>
                                <div>
                                    <h4>Limited Visibility</h4>
                                    <p>No centralized view of deployment status across all clusters</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Solution -->
                    <div class="content-section">
                        <h2>Solution Architecture</h2>
                        <p>
                            Implemented a GitOps-based solution using ArgoCD and Terraform to automate the entire 
                            cluster lifecycle and application deployment process:
                        </p>
                        <div class="architecture-features">
                            <div class="feature-box">
                                <h4><i class="fas fa-code-branch"></i> GitOps Workflow</h4>
                                <p>All infrastructure and application configurations stored in Git repositories, enabling version control and audit trails</p>
                            </div>
                            <div class="feature-box">
                                <h4><i class="fas fa-sync"></i> Automated Sync</h4>
                                <p>ArgoCD continuously monitors Git repos and automatically syncs changes to clusters</p>
                            </div>
                            <div class="feature-box">
                                <h4><i class="fas fa-shield-alt"></i> Policy Enforcement</h4>
                                <p>Implemented OPA (Open Policy Agent) for automated policy validation before deployment</p>
                            </div>
                            <div class="feature-box">
                                <h4><i class="fas fa-chart-line"></i> Observability</h4>
                                <p>Integrated Prometheus and Grafana for real-time monitoring and alerting</p>
                            </div>
                        </div>
                    </div>

                    <!-- Implementation -->
                    <div class="content-section">
                        <h2>Implementation Details</h2>
                        <div class="tech-implementation">
                            <div class="impl-step">
                                <div class="step-number">1</div>
                                <div class="step-content">
                                    <h4>Infrastructure as Code</h4>
                                    <p>Created Terraform modules to provision EKS clusters across AWS regions with standardized configurations including networking, IAM roles, and cluster add-ons</p>
                                    <div class="code-snippet">
                                        <code>
module "eks_cluster" {<br>
&nbsp;&nbsp;source = "./modules/eks"<br>
&nbsp;&nbsp;cluster_name = var.cluster_name<br>
&nbsp;&nbsp;vpc_id = module.vpc.vpc_id<br>
&nbsp;&nbsp;node_groups = var.node_groups<br>
}
                                        </code>
                                    </div>
                                </div>
                            </div>
                            <div class="impl-step">
                                <div class="step-number">2</div>
                                <div class="step-content">
                                    <h4>ArgoCD Setup</h4>
                                    <p>Deployed ArgoCD in HA mode with ApplicationSets for managing applications across multiple clusters, enabling templating and automation</p>
                                </div>
                            </div>
                            <div class="impl-step">
                                <div class="step-number">3</div>
                                <div class="step-content">
                                    <h4>CI/CD Integration</h4>
                                    <p>Integrated with GitHub Actions to automate image builds, security scanning, and manifest generation upon code commits</p>
                                </div>
                            </div>
                            <div class="impl-step">
                                <div class="step-number">4</div>
                                <div class="step-content">
                                    <h4>Progressive Delivery</h4>
                                    <p>Implemented Argo Rollouts for canary and blue-green deployments with automated rollback based on metrics</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Results -->
                    <div class="content-section">
                        <h2>Results & Impact</h2>
                        <div class="results-grid">
                            <div class="result-card">
                                <div class="result-icon"><i class="fas fa-tachometer-alt"></i></div>
                                <h3>85%</h3>
                                <p>Reduction in deployment time</p>
                            </div>
                            <div class="result-card">
                                <div class="result-icon"><i class="fas fa-check-circle"></i></div>
                                <h3>99.9%</h3>
                                <p>Deployment success rate</p>
                            </div>
                            <div class="result-card">
                                <div class="result-icon"><i class="fas fa-undo"></i></div>
                                <h3>2 min</h3>
                                <p>Automated rollback time</p>
                            </div>
                            <div class="result-card">
                                <div class="result-icon"><i class="fas fa-users-cog"></i></div>
                                <h3>20+</h3>
                                <p>Teams onboarded</p>
                            </div>
                        </div>
                    </div>

                    <!-- Lessons Learned -->
                    <div class="content-section">
                        <h2>Key Takeaways</h2>
                        <ul class="takeaways-list">
                            <li><i class="fas fa-lightbulb"></i> GitOps significantly improves deployment reliability and provides excellent audit capabilities</li>
                            <li><i class="fas fa-lightbulb"></i> Standardization across clusters is crucial for maintainability at scale</li>
                            <li><i class="fas fa-lightbulb"></i> Progressive delivery strategies reduce risk and increase confidence in deployments</li>
                            <li><i class="fas fa-lightbulb"></i> Comprehensive monitoring and alerting are essential for automated workflows</li>
                            <li><i class="fas fa-lightbulb"></i> Developer experience and documentation are key to successful adoption</li>
                        </ul>
                    </div>
                </div>

